{
	"name": "notion-avatar-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"pre-commit": "bun run format && bun run lint && bun run check",
		"release:registry": "jsrepo publish"
	},
	"devDependencies": {
		"@eslint/compat": "2.0.5",
		"@eslint/js": "10.0.1",
		"@shikijs/langs": "4.0.2",
		"@shikijs/themes": "4.0.2",
		"@sveltejs/adapter-vercel": "6.3.3",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.2.4",
		"@types/dompurify": "3.2.0",
		"bits-ui": "2.18.0",
		"clsx": "2.1.1",
		"dompurify": "3.4.1",
		"eslint": "10.2.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"globals": "17.5.0",
		"jsrepo": "3.7.0",
		"lint-staged": "16.4.0",
		"mode-watcher": "1.1.0",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.3",
		"shiki": "4.0.2",
		"svelte": "5.55.4",
		"svelte-check": "4.4.6",
		"svelte-sonner": "1.1.0",
		"tailwindcss": "4.2.4",
		"tw-animate-css": "1.4.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.59.0",
		"vite": "8.0.10"
	},
	"dependencies": {
		"@lucide/svelte": "^0.577.0",
		"@lukulent/svelte-umami": "^0.0.4",
		"@vercel/analytics": "^2.0.0",
		"@vercel/speed-insights": "^2.0.0",
		"runed": "^0.37.0",
		"tailwind-merge": "^3.3.0",
		"tailwind-variants": "^3.0.0"
	},
	"lint-staged": {
		"*.{js,ts,svelte,html,css,md,json}": "prettier --write",
		"*.{js,ts,svelte}": "eslint .",
		"*.svelte": "svelte-check --tsconfig ./tsconfig.json"
	}
}
